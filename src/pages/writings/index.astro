---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostEntry from '../../components/PostEntry.astro';
import TagCloud from '../../components/TagCloud.astro';
import { getCollection } from 'astro:content';
import { readingTime, deriveSlug, getAllTags } from '../../utils/index';

const writings = await getCollection('writings', ({ data }) => !data.draft);
const sorted = writings.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const tags = getAllTags(writings);
---
<BaseLayout title="Writings">
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">💻&ensp;Writings ({writings.length})</h1>
    </header>
    <TagCloud tags={tags} />
    <div class="post-content feed">
      {sorted.map(post => {
        const slug = deriveSlug(post.id, post.data.permalink);
        const url = `/writings/${slug}`;
        const rt = readingTime(post.body, post.data.reading_time);
        return (
          <PostEntry
            url={url}
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            modifiedDate={post.data.modified_date}
            tags={post.data.tags}
            readingTime={rt}
            isRedirect={!!post.data.redirect_to}
          />
        );
      })}
    </div>
  </article>
</BaseLayout>
