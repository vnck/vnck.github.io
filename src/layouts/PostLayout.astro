---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils/index';

interface Props {
  title: string;
  date: Date;
  tags?: string[];
  description?: string;
  image?: string;
  modifiedDate?: Date;
  readingTime: number;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, date, tags = [], description, image, modifiedDate, readingTime, headings = [] } = Astro.props;
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 3;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description ?? '',
  datePublished: date.toISOString(),
  ...(modifiedDate && { dateModified: modifiedDate.toISOString() }),
  author: { '@type': 'Person', name: 'Ivan Chuang', url: 'https://vnck.xyz/about' },
  publisher: { '@type': 'Person', name: 'Ivan Chuang', url: 'https://vnck.xyz' },
  ...(image && { image: `https://vnck.xyz${image}` }),
});
---
<BaseLayout title={title} description={description} image={image} ogType="article">
  <Fragment slot="head-extra">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <article class="post h-entry" itemscope itemtype="http://schema.org/BlogPosting">
    <header class="post-header">
      <h1 class="post-title p-name" itemprop="name headline">{title}</h1>
      <div class="post-meta">
        {modifiedDate ? (
          <>
            <p style="text-decoration:line-through;">{formatDate(date)}</p>
            <p>&nbsp;&nbsp;{formatDate(modifiedDate)}</p>
          </>
        ) : (
          <p>{formatDate(date)}</p>
        )}
        <p>&ensp;·&ensp;</p>
        <p>{readingTime} min</p>
        <p>&ensp;·&ensp;</p>
        <p>
          {tags.map(tag => (
            <a href={`/tags/${tag}`}><code class="tag">{tag}</code></a>
          ))}
        </p>
      </div>
    </header>

    {showToc && (
      <nav class="toc" aria-label="Table of contents">
        <p class="toc-title">Contents</p>
        <ol>
          {tocHeadings.map(h => (
            <li class={h.depth === 3 ? 'toc-h3' : ''}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="post-content e-content" itemprop="articleBody">
      <slot />
    </div>

    <div>
      <hr />
      <script is:inline>
        (function() {
          const dark = document.documentElement.getAttribute('data-theme') === 'dark';
          const s = document.createElement('script');
          s.src = 'https://utteranc.es/client.js';
          s.setAttribute('repo', 'vnck/vnck-comments');
          s.setAttribute('issue-term', 'url');
          s.setAttribute('theme', dark ? 'github-dark' : 'github-light');
          s.setAttribute('crossorigin', 'anonymous');
          s.async = true;
          document.currentScript.parentNode.appendChild(s);
        })();
      </script>
    </div>
  </article>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.9/MathJax.js?config=TeX-AMS-MML_HTMLorMML" is:inline></script>

  <script is:inline>
    // Heading anchor links
    document.querySelectorAll('.post-content h2, .post-content h3, .post-content h4').forEach(h => {
      if (!h.id) return;
      const a = document.createElement('a');
      a.href = '#' + h.id;
      a.className = 'heading-anchor';
      a.textContent = '#';
      h.appendChild(a);
    });

    // Copy buttons on code blocks
    document.querySelectorAll('.post-content pre').forEach(pre => {
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = 'copy';
      btn.addEventListener('click', () => {
        const code = pre.querySelector('code');
        navigator.clipboard.writeText(code ? code.innerText : pre.innerText).then(() => {
          btn.textContent = 'copied!';
          setTimeout(() => btn.textContent = 'copy', 2000);
        });
      });
      pre.appendChild(btn);
    });
  </script>
</BaseLayout>
